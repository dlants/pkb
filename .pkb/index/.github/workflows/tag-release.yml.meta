  "blobSha": "92febf8bb080b8da045534adbbd33e619137327d",
  "modelName": "voyage-context-4@256",
  "chunks": [
    {
      "text": "name: tag release\n\n# Auto-tag main with an incremented semver patch so that\n# `go install github.com/dlants/pkb@latest` always resolves to the\n# latest code on main. Runs after code lands; tag pushes don't trigger this\n# workflow (push tag events are filtered out by the branches filter), and\n# standalone index-only commits are skipped via paths-ignore.\non:\n  push:\n    branches: [main]\n    paths-ignore:\n      - pkb.db\n      - pkb-state.toml\n\nconcurrency:\n  group: tag-release\n  cancel-in-progress: false\n\npermissions:\n  contents: write\n\njobs:\n  tag:\n    runs-on: ubuntu-latest\n    steps:\n      - uses: actions/checkout@v4\n        with:\n          fetch-depth: 0\n          fetch-tags: true\n      - name: Compute and push next tag\n        run: |\n          set -euo pipefail\n          latest=$(git tag -l 'v*' --sort=-v:refname | head -n1)\n          if [ -z \"$latest\" ]; then\n            next=\"v0.1.0\"\n          else\n            ver=${latest#v}\n            major=${ver%%.*}\n            rest=${ver#*.}\n            minor=${rest%%.*}\n            patch=${rest#*.}\n            next=\"v${major}.${minor}.$((patch + 1))\"\n          fi\n          echo \"tagging $next\"\n          git tag \"$next\"\n          git push origin \"$next\"\n",
      "contextualizedText": "# .github/workflows/tag-release.yml\n\nname: tag release\n\n# Auto-tag main with an incremented semver patch so that\n# `go install github.com/dlants/pkb@latest` always resolves to the\n# latest code on main. Runs after code lands; tag pushes don't trigger this\n# workflow (push tag events are filtered out by the branches filter), and\n# standalone index-only commits are skipped via paths-ignore.\non:\n  push:\n    branches: [main]\n    paths-ignore:\n      - pkb.db\n      - pkb-state.toml\n\nconcurrency:\n  group: tag-release\n  cancel-in-progress: false\n\npermissions:\n  contents: write\n\njobs:\n  tag:\n    runs-on: ubuntu-latest\n    steps:\n      - uses: actions/checkout@v4\n        with:\n          fetch-depth: 0\n          fetch-tags: true\n      - name: Compute and push next tag\n        run: |\n          set -euo pipefail\n          latest=$(git tag -l 'v*' --sort=-v:refname | head -n1)\n          if [ -z \"$latest\" ]; then\n            next=\"v0.1.0\"\n          else\n            ver=${latest#v}\n            major=${ver%%.*}\n            rest=${ver#*.}\n            minor=${rest%%.*}\n            patch=${rest#*.}\n            next=\"v${major}.${minor}.$((patch + 1))\"\n          fi\n          echo \"tagging $next\"\n          git tag \"$next\"\n          git push origin \"$next\"\n",
