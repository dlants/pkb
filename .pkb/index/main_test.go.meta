      "text": "func TestStatsNoIndex(t *testing.T) {\n\tsetupRepo(t)\n\tout, err := captureStdout(t, func() error { return runStats(nil) })\n\trequire.NoError(t, err)\n\trequire.True(t, strings.Contains(out, \"no index yet\"))\n}",
