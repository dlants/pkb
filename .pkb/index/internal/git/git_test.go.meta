    {
      "text": "func gitCmd(t *testing.T, dir string, args ...string) string {\n\tt.Helper()\n\tcmd := exec.Command(\"git\", args...)\n\tcmd.Dir = dir\n\tcmd.Env = append(os.Environ(),\n\t\t\"GIT_AUTHOR_NAME=test\", \"GIT_AUTHOR_EMAIL=test@test\",\n\t\t\"GIT_COMMITTER_NAME=test\", \"GIT_COMMITTER_EMAIL=test@test\",\n\t)\n\tout, err := cmd.CombinedOutput()\n\tif err != nil {\n\t\tt.Fatalf(\"git %v: %v: %s\", args, err, out)\n\t}\n\treturn string(out)\n}",
      "contextualizedText": "// internal/git/git_test.go \u003e function gitCmd\n\nfunc gitCmd(t *testing.T, dir string, args ...string) string {\n\tt.Helper()\n\tcmd := exec.Command(\"git\", args...)\n\tcmd.Dir = dir\n\tcmd.Env = append(os.Environ(),\n\t\t\"GIT_AUTHOR_NAME=test\", \"GIT_AUTHOR_EMAIL=test@test\",\n\t\t\"GIT_COMMITTER_NAME=test\", \"GIT_COMMITTER_EMAIL=test@test\",\n\t)\n\tout, err := cmd.CombinedOutput()\n\tif err != nil {\n\t\tt.Fatalf(\"git %v: %v: %s\", args, err, out)\n\t}\n\treturn string(out)\n}",
      "headingContext": "internal/git/git_test.go \u003e function gitCmd",
