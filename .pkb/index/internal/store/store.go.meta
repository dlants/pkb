    {
      "text": "func deserializeFloat32(b []byte) embed.Embedding {\n\tout := make(embed.Embedding, len(b)/4)\n\tfor i := range out {\n\t\tout[i] = math.Float32frombits(binary.LittleEndian.Uint32(b[i*4:]))\n\t}\n\treturn out\n}",
      "contextualizedText": "// internal/store/store.go \u003e function deserializeFloat32\n\nfunc deserializeFloat32(b []byte) embed.Embedding {\n\tout := make(embed.Embedding, len(b)/4)\n\tfor i := range out {\n\t\tout[i] = math.Float32frombits(binary.LittleEndian.Uint32(b[i*4:]))\n\t}\n\treturn out\n}",
      "headingContext": "internal/store/store.go \u003e function deserializeFloat32",
