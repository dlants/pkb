    {
      "text": "// Stats holds index counts for a model.\ntype Stats struct {\n\tFiles  int\n\tChunks int\n}",
      "contextualizedText": "// internal/store/store.go \u003e type Stats\n\n// Stats holds index counts for a model.\ntype Stats struct {\n\tFiles  int\n\tChunks int\n}",
