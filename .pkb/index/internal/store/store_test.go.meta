    {
      "text": "func openTestStore(t *testing.T) (*Store, *embed.MockModel) {\n\tt.Helper()\n\tdir := t.TempDir()\n\ts, err := Open(filepath.Join(dir, \"test.db\"))\n\tif err != nil {\n\t\tt.Fatalf(\"Open: %v\", err)\n\t}\n\tt.Cleanup(func() { s.Close() })\n\tm := embed.NewMockModel(\"mock@8\", 8)\n\tif err := s.EnsureVecTable(m.ModelName(), m.Dimensions()); err != nil {\n\t\tt.Fatalf(\"EnsureVecTable: %v\", err)\n\t}\n\treturn s, m\n}",
      "contextualizedText": "// internal/store/store_test.go \u003e function openTestStore\n\nfunc openTestStore(t *testing.T) (*Store, *embed.MockModel) {\n\tt.Helper()\n\tdir := t.TempDir()\n\ts, err := Open(filepath.Join(dir, \"test.db\"))\n\tif err != nil {\n\t\tt.Fatalf(\"Open: %v\", err)\n\t}\n\tt.Cleanup(func() { s.Close() })\n\tm := embed.NewMockModel(\"mock@8\", 8)\n\tif err := s.EnsureVecTable(m.ModelName(), m.Dimensions()); err != nil {\n\t\tt.Fatalf(\"EnsureVecTable: %v\", err)\n\t}\n\treturn s, m\n}",
      "headingContext": "internal/store/store_test.go \u003e function openTestStore",
