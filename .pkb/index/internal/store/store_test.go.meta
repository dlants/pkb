    {
      "text": "func emb(t *testing.T, m *embed.MockModel, text string) embed.Embedding {\n\tt.Helper()\n\te, err := m.EmbedChunk(text)\n\tif err != nil {\n\t\tt.Fatalf(\"EmbedChunk: %v\", err)\n\t}\n\treturn e\n}",
      "contextualizedText": "// internal/store/store_test.go \u003e function emb\n\nfunc emb(t *testing.T, m *embed.MockModel, text string) embed.Embedding {\n\tt.Helper()\n\te, err := m.EmbedChunk(text)\n\tif err != nil {\n\t\tt.Fatalf(\"EmbedChunk: %v\", err)\n\t}\n\treturn e\n}",
