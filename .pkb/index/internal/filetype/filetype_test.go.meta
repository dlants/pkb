    {
      "text": "func TestRouteExtHCL(t *testing.T) {\n\tfor _, ext := range []string{\".tf\", \".hcl\"} {\n\t\tr := RouteExt(ext)\n\t\tif r.Type != Code || r.Grammar != \"hcl\" {\n\t\t\tt.Fatalf(\"RouteExt(%q) = %+v, want {Code hcl}\", ext, r)\n\t\t}\n\t}\n}",
      "contextualizedText": "// internal/filetype/filetype_test.go \u003e function TestRouteExtHCL\n\nfunc TestRouteExtHCL(t *testing.T) {\n\tfor _, ext := range []string{\".tf\", \".hcl\"} {\n\t\tr := RouteExt(ext)\n\t\tif r.Type != Code || r.Grammar != \"hcl\" {\n\t\t\tt.Fatalf(\"RouteExt(%q) = %+v, want {Code hcl}\", ext, r)\n\t\t}\n\t}\n}",
