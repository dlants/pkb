      "startCol": 1,
      "endLine": 98,
      "endCol": 2
    },
    {
      "text": "// ModelName returns the model identifier used to key vec tables.\nfunc (v *Voyage) ModelName() string { return v.name }",
      "contextualizedText": "// internal/embed/voyage.go \u003e method ModelName\n\n// ModelName returns the model identifier used to key vec tables.\nfunc (v *Voyage) ModelName() string { return v.name }",
