      "endCol": 2
    },
    {
      "text": "type voyageEmbeddingRequest struct {\n\tModel           string   `json:\"model\"`\n\tInput           []string `json:\"input\"`\n\tInputType       string   `json:\"input_type,omitempty\"`\n\tOutputDimension int      `json:\"output_dimension,omitempty\"`\n}",
      "contextualizedText": "// internal/embed/voyage.go \u003e type voyageEmbeddingRequest\n\ntype voyageEmbeddingRequest struct {\n\tModel           string   `json:\"model\"`\n\tInput           []string `json:\"input\"`\n\tInputType       string   `json:\"input_type,omitempty\"`\n\tOutputDimension int      `json:\"output_dimension,omitempty\"`\n}",
      "headingContext": "internal/embed/voyage.go \u003e type voyageEmbeddingRequest",
