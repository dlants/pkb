    {
      "text": "func TestVoyageEmbedDocumentErrorStatus(t *testing.T) {\n\tsrv := httptest.NewServer(http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusUnauthorized)\n\t\t_, _ = w.Write([]byte(`{\"detail\":\"bad key\"}`))\n\t}))\n\tdefer srv.Close()\n\n\tm, err := NewVoyage(srv.URL, \"VOYAGE_API_KEY\", \"voyage-context-4\", 4)\n\tif err != nil {\n\t\tt.Fatal(err)\n\t}\n\tif _, err := m.EmbedDocument(\"x\"); err == nil {\n\t\tt.Fatal(\"expected error on non-2xx status\")\n\t}\n}",
      "contextualizedText": "// internal/embed/voyage_test.go \u003e function TestVoyageEmbedDocumentErrorStatus\n\nfunc TestVoyageEmbedDocumentErrorStatus(t *testing.T) {\n\tsrv := httptest.NewServer(http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusUnauthorized)\n\t\t_, _ = w.Write([]byte(`{\"detail\":\"bad key\"}`))\n\t}))\n\tdefer srv.Close()\n\n\tm, err := NewVoyage(srv.URL, \"VOYAGE_API_KEY\", \"voyage-context-4\", 4)\n\tif err != nil {\n\t\tt.Fatal(err)\n\t}\n\tif _, err := m.EmbedDocument(\"x\"); err == nil {\n\t\tt.Fatal(\"expected error on non-2xx status\")\n\t}\n}",
