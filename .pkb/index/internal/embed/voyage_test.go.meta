      "endCol": 2
    },
    {
      "text": "func TestVoyageEmbed(t *testing.T) {\n\tsrv := newFakeVoyageServer(t, 4)\n\tdefer srv.Close()\n\n\tm, err := NewVoyage(srv.URL, \"VOYAGE_API_KEY\", \"voyage-code-3\", 4)\n\tif err != nil {\n\t\tt.Fatal(err)\n\t}\n\tif m.ModelName() != \"voyage-code-3@4\" {\n\t\tt.Fatalf(\"unexpected name %q\", m.ModelName())\n\t}\n\tif m.Dimensions() != 4 {\n\t\tt.Fatalf(\"unexpected dims %d\", m.Dimensions())\n\t}\n\n\tchunk, err := m.EmbedChunk(\"hello\")\n\tif err != nil {\n\t\tt.Fatal(err)\n\t}\n\tif len(chunk) != 4 {\n\t\tt.Fatalf(\"expected 4 dims, got %d\", len(chunk))\n\t}\n\n\tq, err := m.EmbedQuery(\"query\")\n\tif err != nil {\n\t\tt.Fatal(err)\n\t}\n\tif len(q) != 4 {\n\t\tt.Fatalf(\"expected 4 dims, got %d\", len(q))\n\t}\n\n\tbatch, err := m.EmbedChunks([]string{\"a\", \"b\", \"c\"})\n\tif err != nil {\n\t\tt.Fatal(err)\n\t}\n\tif len(batch) != 3 {\n\t\tt.Fatalf(\"expected 3 embeddings, got %d\", len(batch))\n\t}\n\tfor i, e := range batch {\n\t\tif len(e) != 4 {\n\t\t\tt.Fatalf(\"embedding %d: expected 4 dims, got %d\", i, len(e))\n\t\t}\n\t}\n}",
      "contextualizedText": "// internal/embed/voyage_test.go \u003e function TestVoyageEmbed\n\nfunc TestVoyageEmbed(t *testing.T) {\n\tsrv := newFakeVoyageServer(t, 4)\n\tdefer srv.Close()\n\n\tm, err := NewVoyage(srv.URL, \"VOYAGE_API_KEY\", \"voyage-code-3\", 4)\n\tif err != nil {\n\t\tt.Fatal(err)\n\t}\n\tif m.ModelName() != \"voyage-code-3@4\" {\n\t\tt.Fatalf(\"unexpected name %q\", m.ModelName())\n\t}\n\tif m.Dimensions() != 4 {\n\t\tt.Fatalf(\"unexpected dims %d\", m.Dimensions())\n\t}\n\n\tchunk, err := m.EmbedChunk(\"hello\")\n\tif err != nil {\n\t\tt.Fatal(err)\n\t}\n\tif len(chunk) != 4 {\n\t\tt.Fatalf(\"expected 4 dims, got %d\", len(chunk))\n\t}\n\n\tq, err := m.EmbedQuery(\"query\")\n\tif err != nil {\n\t\tt.Fatal(err)\n\t}\n\tif len(q) != 4 {\n\t\tt.Fatalf(\"expected 4 dims, got %d\", len(q))\n\t}\n\n\tbatch, err := m.EmbedChunks([]string{\"a\", \"b\", \"c\"})\n\tif err != nil {\n\t\tt.Fatal(err)\n\t}\n\tif len(batch) != 3 {\n\t\tt.Fatalf(\"expected 3 embeddings, got %d\", len(batch))\n\t}\n\tfor i, e := range batch {\n\t\tif len(e) != 4 {\n\t\t\tt.Fatalf(\"embedding %d: expected 4 dims, got %d\", i, len(e))\n\t\t}\n\t}\n}",
