    },
    {
      "text": "func TestDeterministic(t *testing.T) {\n\tin := fixture()\n\tm1, v1, err := Encode(in)\n\tif err != nil {\n\t\tt.Fatal(err)\n\t}\n\tm2, v2, err := Encode(in)\n\tif err != nil {\n\t\tt.Fatal(err)\n\t}\n\tif !bytes.Equal(m1, m2) {\n\t\tt.Error(\"meta bytes not deterministic\")\n\t}\n\tif !bytes.Equal(v1, v2) {\n\t\tt.Error(\"vec bytes not deterministic\")\n\t}\n}",
      "contextualizedText": "// internal/mirror/mirror_test.go \u003e function TestDeterministic\n\nfunc TestDeterministic(t *testing.T) {\n\tin := fixture()\n\tm1, v1, err := Encode(in)\n\tif err != nil {\n\t\tt.Fatal(err)\n\t}\n\tm2, v2, err := Encode(in)\n\tif err != nil {\n\t\tt.Fatal(err)\n\t}\n\tif !bytes.Equal(m1, m2) {\n\t\tt.Error(\"meta bytes not deterministic\")\n\t}\n\tif !bytes.Equal(v1, v2) {\n\t\tt.Error(\"vec bytes not deterministic\")\n\t}\n}",
      "headingContext": "internal/mirror/mirror_test.go \u003e function TestDeterministic",
