      "text": "func fixture() Artifact {\n\treturn Artifact{\n\t\tBlobSha:   \"deadbeef\",\n\t\tModelName: \"mock@8\",\n\t\tChunks: []Chunk{\n\t\t\t{\n\t\t\t\tStart:          10,\n\t\t\t\tEnd:            42,\n\t\t\t\tHeadingContext: \"pkg \u003e Foo\",\n\t\t\t\tEmbedding:      embed.Embedding{0.1, -0.2, 3.5, 0},\n\t\t\t},\n\t\t\t{\n\t\t\t\tStart:          64,\n\t\t\t\tEnd:            68,\n\t\t\t\tHeadingContext: \"\",\n\t\t\t\tEmbedding:      embed.Embedding{-1, 2, -3, 4},\n\t\t\t},\n\t\t},\n\t}\n}",
      "contextualizedText": "// internal/mirror/mirror_test.go \u003e function fixture\n\nfunc fixture() Artifact {\n\treturn Artifact{\n\t\tBlobSha:   \"deadbeef\",\n\t\tModelName: \"mock@8\",\n\t\tChunks: []Chunk{\n\t\t\t{\n\t\t\t\tStart:          10,\n\t\t\t\tEnd:            42,\n\t\t\t\tHeadingContext: \"pkg \u003e Foo\",\n\t\t\t\tEmbedding:      embed.Embedding{0.1, -0.2, 3.5, 0},\n\t\t\t},\n\t\t\t{\n\t\t\t\tStart:          64,\n\t\t\t\tEnd:            68,\n\t\t\t\tHeadingContext: \"\",\n\t\t\t\tEmbedding:      embed.Embedding{-1, 2, -3, 4},\n\t\t\t},\n\t\t},\n\t}\n}",
