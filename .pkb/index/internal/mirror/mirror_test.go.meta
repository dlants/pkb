    {
      "text": "func TestRoundTrip(t *testing.T) {\n\tin := fixture()\n\tmeta, vec, err := Encode(in)\n\tif err != nil {\n\t\tt.Fatal(err)\n\t}\n\tgot, err := Decode(meta, vec)\n\tif err != nil {\n\t\tt.Fatal(err)\n\t}\n\tif !reflect.DeepEqual(got, in) {\n\t\tt.Fatalf(\"round-trip mismatch:\\n got %+v\\nwant %+v\", got, in)\n\t}\n}",
      "contextualizedText": "// internal/mirror/mirror_test.go \u003e function TestRoundTrip\n\nfunc TestRoundTrip(t *testing.T) {\n\tin := fixture()\n\tmeta, vec, err := Encode(in)\n\tif err != nil {\n\t\tt.Fatal(err)\n\t}\n\tgot, err := Decode(meta, vec)\n\tif err != nil {\n\t\tt.Fatal(err)\n\t}\n\tif !reflect.DeepEqual(got, in) {\n\t\tt.Fatalf(\"round-trip mismatch:\\n got %+v\\nwant %+v\", got, in)\n\t}\n}",
