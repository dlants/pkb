    {
      "text": "package chunk\n\nimport (\n\t\"sort\"\n\t\"strings\"\n\n\ttree_sitter \"github.com/tree-sitter/go-tree-sitter\"\n)",
      "contextualizedText": "// internal/chunk/defindex.go\n\npackage chunk\n\nimport (\n\t\"sort\"\n\t\"strings\"\n\n\ttree_sitter \"github.com/tree-sitter/go-tree-sitter\"\n)",
      "headingContext": "internal/chunk/defindex.go",
