      "text": "func TestCodeBreadcrumberUnknownGrammar(t *testing.T) {\n\tb, err := NewCodeBreadcrumber([]byte(\"hello world\"), \"cobol\", \"x.cbl\")\n\tif err != nil {\n\t\tt.Fatal(err)\n\t}\n\tif got := b.Breadcrumb(0, 5); got != \"x.cbl\" {\n\t\tt.Fatalf(\"fallback: got %q\", got)\n\t}\n}",
