    {
      "text": "// pathAt parses src and returns the config path of the smallest window covering\n// the first occurrence of marker.\nfunc pathAt(t *testing.T, grammar, src, marker string) string {\n\tt.Helper()\n\tp := tree_sitter.NewParser()\n\tdefer p.Close()\n\tif err := p.SetLanguage(languageFor(grammar)); err != nil {\n\t\tt.Fatalf(\"set language: %v\", err)\n\t}\n\ttree := p.Parse([]byte(src), nil)\n\tdefer tree.Close()\n\tlo := strings.Index(src, marker)\n\tif lo \u003c 0 {\n\t\tt.Fatalf(\"marker %q not found\", marker)\n\t}\n\treturn configPath(tree.RootNode(), []byte(src), lo, lo+len(marker))\n}",
      "contextualizedText": "// internal/chunk/config_test.go \u003e function pathAt\n\n// pathAt parses src and returns the config path of the smallest window covering\n// the first occurrence of marker.\nfunc pathAt(t *testing.T, grammar, src, marker string) string {\n\tt.Helper()\n\tp := tree_sitter.NewParser()\n\tdefer p.Close()\n\tif err := p.SetLanguage(languageFor(grammar)); err != nil {\n\t\tt.Fatalf(\"set language: %v\", err)\n\t}\n\ttree := p.Parse([]byte(src), nil)\n\tdefer tree.Close()\n\tlo := strings.Index(src, marker)\n\tif lo \u003c 0 {\n\t\tt.Fatalf(\"marker %q not found\", marker)\n\t}\n\treturn configPath(tree.RootNode(), []byte(src), lo, lo+len(marker))\n}",
      "headingContext": "internal/chunk/config_test.go \u003e function pathAt",
      "startLine": 10,
      "startCol": 1,
      "endLine": 26,
      "endCol": 2
    },
    {
      "text": "func TestConfigPathJSON(t *testing.T) {\n\tsrc := `{\"deps\":{\"nested\":{\"x\":{\"y\":1}}},\"list\":[10,20,30]}`\n\tcases := map[string]string{\n\t\t`\"nested\"`: \"deps.nested\",\n\t\t`\"y\":1`:    \"deps.nested.x.y\",\n\t\t`20`:       \"list[1]\",\n\t\t`30`:       \"list[2]\",\n\t}\n\tfor marker, want := range cases {\n\t\tif got := pathAt(t, \"json\", src, marker); got != want {\n\t\t\tt.Errorf(\"marker %q: got %q want %q\", marker, got, want)\n\t\t}\n\t}\n}",
      "contextualizedText": "// internal/chunk/config_test.go \u003e function TestConfigPathJSON\n\nfunc TestConfigPathJSON(t *testing.T) {\n\tsrc := `{\"deps\":{\"nested\":{\"x\":{\"y\":1}}},\"list\":[10,20,30]}`\n\tcases := map[string]string{\n\t\t`\"nested\"`: \"deps.nested\",\n\t\t`\"y\":1`:    \"deps.nested.x.y\",\n\t\t`20`:       \"list[1]\",\n\t\t`30`:       \"list[2]\",\n\t}\n\tfor marker, want := range cases {\n\t\tif got := pathAt(t, \"json\", src, marker); got != want {\n\t\t\tt.Errorf(\"marker %q: got %q want %q\", marker, got, want)\n\t\t}\n\t}\n}",
      "headingContext": "internal/chunk/config_test.go \u003e function TestConfigPathJSON",
