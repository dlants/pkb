      "text": "package chunk\n\nimport (\n\t\"strings\"\n\t\"testing\"\n\n\ttree_sitter \"github.com/tree-sitter/go-tree-sitter\"\n)",
      "contextualizedText": "// internal/chunk/config_test.go\n\npackage chunk\n\nimport (\n\t\"strings\"\n\t\"testing\"\n\n\ttree_sitter \"github.com/tree-sitter/go-tree-sitter\"\n)",
      "headingContext": "internal/chunk/config_test.go",
