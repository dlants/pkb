    {
      "text": "func TestChunkConfigSingleChunkRootBreadcrumb(t *testing.T) {\n\tchunks, err := ChunkConfig([]byte(`{\"a\":1,\"b\":2}`), \"json\", \"f.json\", TargetChunkSize)\n\tif err != nil {\n\t\tt.Fatal(err)\n\t}\n\tif len(chunks) != 1 {\n\t\tt.Fatalf(\"got %d chunks want 1\", len(chunks))\n\t}\n\tif chunks[0].HeadingContext != \"f.json\" {\n\t\tt.Errorf(\"root breadcrumb: got %q want %q\", chunks[0].HeadingContext, \"f.json\")\n\t}\n}",
      "contextualizedText": "// internal/chunk/config_test.go \u003e function TestChunkConfigSingleChunkRootBreadcrumb\n\nfunc TestChunkConfigSingleChunkRootBreadcrumb(t *testing.T) {\n\tchunks, err := ChunkConfig([]byte(`{\"a\":1,\"b\":2}`), \"json\", \"f.json\", TargetChunkSize)\n\tif err != nil {\n\t\tt.Fatal(err)\n\t}\n\tif len(chunks) != 1 {\n\t\tt.Fatalf(\"got %d chunks want 1\", len(chunks))\n\t}\n\tif chunks[0].HeadingContext != \"f.json\" {\n\t\tt.Errorf(\"root breadcrumb: got %q want %q\", chunks[0].HeadingContext, \"f.json\")\n\t}\n}",
      "headingContext": "internal/chunk/config_test.go \u003e function TestChunkConfigSingleChunkRootBreadcrumb",
      "startLine": 71,
      "startCol": 1,
      "endLine": 82,
      "endCol": 2
