      "text": "func TestQueryForUnknownGrammar(t *testing.T) {\n\tif got := queryFor(\"nonexistent\"); got != \"\" {\n\t\tt.Errorf(\"queryFor(unknown) = %q, want empty\", got)\n\t}\n}",
