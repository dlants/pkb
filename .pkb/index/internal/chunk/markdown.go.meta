    {
      "text": "// ChunkMarkdown splits markdown text into chunks along heading and paragraph\n// boundaries, carrying heading breadcrumbs as HeadingContext. pathContext seeds\n// the breadcrumb (typically the file's relative path) so the file path is part\n// of the embedded context, mirroring ChunkCode.\nfunc ChunkMarkdown(text string, pathContext string, maxChunkSize int) []ChunkInfo {\n\tif maxChunkSize \u003c= 0 {\n\t\tmaxChunkSize = TargetChunkSize\n\t}\n\tif strings.TrimSpace(text) == \"\" {\n\t\treturn nil\n\t}\n\n\thardBlocks := splitIntoHardBlocks(text)\n\tvar chunks []ChunkInfo\n\n\tfor _, block := range hardBlocks {\n\t\tblockText := block.text\n\t\tblockStart := block.start\n\t\tfirstLine := strings.SplitN(blockText, \"\\n\", 2)[0]\n\t\tif _, ok := parseHeading(firstLine); ok {\n\t\t\tnewlineIdx := strings.Index(blockText, \"\\n\")\n\t\t\tif newlineIdx != -1 {\n\t\t\t\tblockText = blockText[newlineIdx+1:]\n\t\t\t\tblockStart = Position{Line: block.start.Line + 1, Col: 1}\n\t\t\t} else {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t}\n\n\t\tif strings.TrimSpace(blockText) == \"\" {\n\t\t\tcontinue\n\t\t}\n\n\t\tfor _, sub := range softSplitBlock(blockText, blockStart, maxChunkSize) {\n\t\t\tchunks = append(chunks, ChunkInfo{\n\t\t\t\tText:           sub.text,\n\t\t\t\tHeadingContext: joinBreadcrumb(pathContext, block.headingContext),\n\t\t\t\tStart:          sub.start,\n\t\t\t\tEnd:            sub.end,\n\t\t\t})\n\t\t}\n\t}\n\n\treturn chunks\n}",
      "contextualizedText": "// internal/chunk/markdown.go \u003e function ChunkMarkdown\n\n// ChunkMarkdown splits markdown text into chunks along heading and paragraph\n// boundaries, carrying heading breadcrumbs as HeadingContext. pathContext seeds\n// the breadcrumb (typically the file's relative path) so the file path is part\n// of the embedded context, mirroring ChunkCode.\nfunc ChunkMarkdown(text string, pathContext string, maxChunkSize int) []ChunkInfo {\n\tif maxChunkSize \u003c= 0 {\n\t\tmaxChunkSize = TargetChunkSize\n\t}\n\tif strings.TrimSpace(text) == \"\" {\n\t\treturn nil\n\t}\n\n\thardBlocks := splitIntoHardBlocks(text)\n\tvar chunks []ChunkInfo\n\n\tfor _, block := range hardBlocks {\n\t\tblockText := block.text\n\t\tblockStart := block.start\n\t\tfirstLine := strings.SplitN(blockText, \"\\n\", 2)[0]\n\t\tif _, ok := parseHeading(firstLine); ok {\n\t\t\tnewlineIdx := strings.Index(blockText, \"\\n\")\n\t\t\tif newlineIdx != -1 {\n\t\t\t\tblockText = blockText[newlineIdx+1:]\n\t\t\t\tblockStart = Position{Line: block.start.Line + 1, Col: 1}\n\t\t\t} else {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t}\n\n\t\tif strings.TrimSpace(blockText) == \"\" {\n\t\t\tcontinue\n\t\t}\n\n\t\tfor _, sub := range softSplitBlock(blockText, blockStart, maxChunkSize) {\n\t\t\tchunks = append(chunks, ChunkInfo{\n\t\t\t\tText:           sub.text,\n\t\t\t\tHeadingContext: joinBreadcrumb(pathContext, block.headingContext),\n\t\t\t\tStart:          sub.start,\n\t\t\t\tEnd:            sub.end,\n\t\t\t})\n\t\t}\n\t}\n\n\treturn chunks\n}",
