    {
      "text": "func getHeadingContext(hierarchy map[int]string) string {\n\tvar parts []string\n\tfor i := 1; i \u003c= 6; i++ {\n\t\tif title, ok := hierarchy[i]; ok \u0026\u0026 title != \"\" {\n\t\t\tparts = append(parts, strings.Repeat(\"#\", i)+\" \"+title)\n\t\t} else {\n\t\t\tbreak\n\t\t}\n\t}\n\treturn strings.Join(parts, \" \u003e \")\n}",
      "contextualizedText": "// internal/chunk/markdown.go \u003e function getHeadingContext\n\nfunc getHeadingContext(hierarchy map[int]string) string {\n\tvar parts []string\n\tfor i := 1; i \u003c= 6; i++ {\n\t\tif title, ok := hierarchy[i]; ok \u0026\u0026 title != \"\" {\n\t\t\tparts = append(parts, strings.Repeat(\"#\", i)+\" \"+title)\n\t\t} else {\n\t\t\tbreak\n\t\t}\n\t}\n\treturn strings.Join(parts, \" \u003e \")\n}",
      "headingContext": "internal/chunk/markdown.go \u003e function getHeadingContext",
