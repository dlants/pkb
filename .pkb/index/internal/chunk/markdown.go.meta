      "text": "func positionAtOffset(text string, start Position, offset int) Position {\n\tline := start.Line\n\tcol := start.Col\n\tfor i := 0; i \u003c offset \u0026\u0026 i \u003c len(text); i++ {\n\t\tif text[i] == '\\n' {\n\t\t\tline++\n\t\t\tcol = 1\n\t\t} else {\n\t\t\tcol++\n\t\t}\n\t}\n\treturn Position{Line: line, Col: col}\n}",
      "contextualizedText": "// internal/chunk/markdown.go \u003e function positionAtOffset\n\nfunc positionAtOffset(text string, start Position, offset int) Position {\n\tline := start.Line\n\tcol := start.Col\n\tfor i := 0; i \u003c offset \u0026\u0026 i \u003c len(text); i++ {\n\t\tif text[i] == '\\n' {\n\t\t\tline++\n\t\t\tcol = 1\n\t\t} else {\n\t\t\tcol++\n\t\t}\n\t}\n\treturn Position{Line: line, Col: col}\n}",
      "headingContext": "internal/chunk/markdown.go \u003e function positionAtOffset",
