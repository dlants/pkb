    {
      "text": "func isCodeFence(line string) bool {\n\treturn strings.HasPrefix(line, \"```\")\n}",
      "contextualizedText": "// internal/chunk/markdown.go \u003e function isCodeFence\n\nfunc isCodeFence(line string) bool {\n\treturn strings.HasPrefix(line, \"```\")\n}",
      "headingContext": "internal/chunk/markdown.go \u003e function isCodeFence",
