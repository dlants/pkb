    {
      "text": "func TestBuildDefIndexNoQuery(t *testing.T) {\n\tsrc := []byte(\"x = 1\\n\")\n\tidx, err := buildDefIndex(nil, src, \"nonexistent\")\n\tif err != nil {\n\t\tt.Fatal(err)\n\t}\n\tif idx != nil {\n\t\tt.Fatalf(\"expected nil index for grammar without query, got %+v\", idx)\n\t}\n}",
