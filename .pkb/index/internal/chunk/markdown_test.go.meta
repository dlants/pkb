    {
      "text": "func TestChunkMarkdownSplitsLargeBlock(t *testing.T) {\n\tvar b strings.Builder\n\tb.WriteString(\"# Big\\n\\n\")\n\tfor i := 0; i \u003c 200; i++ {\n\t\tb.WriteString(\"This is a sentence that adds bulk to the document. \")\n\t\tif i%5 == 0 {\n\t\t\tb.WriteString(\"\\n\\n\")\n\t\t}\n\t}\n\tchunks := ChunkMarkdown(b.String(), \"big.md\", 500)\n\tif len(chunks) \u003c 2 {\n\t\tt.Fatalf(\"expected multiple chunks, got %d\", len(chunks))\n\t}\n}",
      "contextualizedText": "// internal/chunk/markdown_test.go \u003e function TestChunkMarkdownSplitsLargeBlock\n\nfunc TestChunkMarkdownSplitsLargeBlock(t *testing.T) {\n\tvar b strings.Builder\n\tb.WriteString(\"# Big\\n\\n\")\n\tfor i := 0; i \u003c 200; i++ {\n\t\tb.WriteString(\"This is a sentence that adds bulk to the document. \")\n\t\tif i%5 == 0 {\n\t\t\tb.WriteString(\"\\n\\n\")\n\t\t}\n\t}\n\tchunks := ChunkMarkdown(b.String(), \"big.md\", 500)\n\tif len(chunks) \u003c 2 {\n\t\tt.Fatalf(\"expected multiple chunks, got %d\", len(chunks))\n\t}\n}",
