      "endLine": 334,
      "endCol": 2
    },
    {
      "text": "// lineSplitRange emits a byte range as one or more line-split chunks under the\n// current breadcrumb.\nfunc (s *sweeper) lineSplitRange(lo, hi int) {\n\ttext := string(s.source[lo:hi])\n\tif strings.TrimSpace(text) == \"\" {\n\t\treturn\n\t}\n\tbc := s.breadcrumb()\n\tif s.breadcrumbFn != nil {\n\t\tbc = s.breadcrumbFn(lo, hi)\n\t}\n\tfor _, sc := range splitCodeByLines(text, posFromByte(s.source, lo), s.budget) {\n\t\ts.out = append(s.out, ChunkInfo{\n\t\t\tText:           sc.text,\n\t\t\tHeadingContext: bc,\n\t\t\tStart:          sc.start,\n\t\t\tEnd:            sc.end,\n\t\t})\n\t}\n}",
      "contextualizedText": "// internal/chunk/code.go \u003e method lineSplitRange\n\n// lineSplitRange emits a byte range as one or more line-split chunks under the\n// current breadcrumb.\nfunc (s *sweeper) lineSplitRange(lo, hi int) {\n\ttext := string(s.source[lo:hi])\n\tif strings.TrimSpace(text) == \"\" {\n\t\treturn\n\t}\n\tbc := s.breadcrumb()\n\tif s.breadcrumbFn != nil {\n\t\tbc = s.breadcrumbFn(lo, hi)\n\t}\n\tfor _, sc := range splitCodeByLines(text, posFromByte(s.source, lo), s.budget) {\n\t\ts.out = append(s.out, ChunkInfo{\n\t\t\tText:           sc.text,\n\t\t\tHeadingContext: bc,\n\t\t\tStart:          sc.start,\n\t\t\tEnd:            sc.end,\n\t\t})\n\t}\n}",
