    },
    {
      "text": "// flush emits the current window as a chunk (dropping whitespace-only windows)\n// and resets it.\nfunc (s *sweeper) flush() {\n\tif s.winStart \u003c 0 {\n\t\treturn\n\t}\n\ttext := string(s.source[s.winStart:s.winEnd])\n\tif strings.TrimSpace(text) != \"\" {\n\t\tbc := s.breadcrumb()\n\t\tif s.breadcrumbFn != nil {\n\t\t\tbc = s.breadcrumbFn(s.winStart, s.winEnd)\n\t\t}\n\t\ts.out = append(s.out, ChunkInfo{\n\t\t\tText:           text,\n\t\t\tHeadingContext: bc,\n\t\t\tStart:          posFromByte(s.source, s.winStart),\n\t\t\tEnd:            posFromByte(s.source, s.winEnd),\n\t\t})\n\t}\n\ts.winStart = -1\n}",
      "contextualizedText": "// internal/chunk/code.go \u003e method flush\n\n// flush emits the current window as a chunk (dropping whitespace-only windows)\n// and resets it.\nfunc (s *sweeper) flush() {\n\tif s.winStart \u003c 0 {\n\t\treturn\n\t}\n\ttext := string(s.source[s.winStart:s.winEnd])\n\tif strings.TrimSpace(text) != \"\" {\n\t\tbc := s.breadcrumb()\n\t\tif s.breadcrumbFn != nil {\n\t\t\tbc = s.breadcrumbFn(s.winStart, s.winEnd)\n\t\t}\n\t\ts.out = append(s.out, ChunkInfo{\n\t\t\tText:           text,\n\t\t\tHeadingContext: bc,\n\t\t\tStart:          posFromByte(s.source, s.winStart),\n\t\t\tEnd:            posFromByte(s.source, s.winEnd),\n\t\t})\n\t}\n\ts.winStart = -1\n}",
