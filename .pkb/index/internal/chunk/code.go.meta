    {
      "text": "// breadcrumb joins the file path with each active span's \"label name\".\nfunc (s *sweeper) breadcrumb() string {\n\tbc := s.pathContext\n\tfor _, sp := range s.stack {\n\t\tbc = joinBreadcrumb(bc, strings.TrimSpace(sp.label+\" \"+sp.name))\n\t}\n\treturn bc\n}",
      "contextualizedText": "// internal/chunk/code.go \u003e method breadcrumb\n\n// breadcrumb joins the file path with each active span's \"label name\".\nfunc (s *sweeper) breadcrumb() string {\n\tbc := s.pathContext\n\tfor _, sp := range s.stack {\n\t\tbc = joinBreadcrumb(bc, strings.TrimSpace(sp.label+\" \"+sp.name))\n\t}\n\treturn bc\n}",
