      "startCol": 1,
      "endLine": 508,
      "endCol": 2
    },
    {
      "text": "func joinBreadcrumb(prefix, desc string) string {\n\tif prefix == \"\" {\n\t\treturn desc\n\t}\n\tif desc == \"\" {\n\t\treturn prefix\n\t}\n\treturn prefix + \" \u003e \" + desc\n}",
      "contextualizedText": "// internal/chunk/code.go \u003e function joinBreadcrumb\n\nfunc joinBreadcrumb(prefix, desc string) string {\n\tif prefix == \"\" {\n\t\treturn desc\n\t}\n\tif desc == \"\" {\n\t\treturn prefix\n\t}\n\treturn prefix + \" \u003e \" + desc\n}",
      "headingContext": "internal/chunk/code.go \u003e function joinBreadcrumb",
      "startLine": 510,
      "startCol": 1,
      "endLine": 518,
      "endCol": 2
    },
    {
      "text": "// lineChunks splits raw content by lines into budget-sized chunks, used as the\n// fallback when no grammar applies or parsing fails.\nfunc lineChunks(content []byte, prefix string, maxChunkSize int) []ChunkInfo {\n\ttext := string(content)\n\tif strings.TrimSpace(text) == \"\" {\n\t\treturn nil\n\t}\n\tvar out []ChunkInfo\n\tfor _, sc := range splitCodeByLines(text, Position{Line: 1, Col: 1}, maxChunkSize) {\n\t\tout = append(out, ChunkInfo{\n\t\t\tText:           sc.text,\n\t\t\tHeadingContext: prefix,\n\t\t\tStart:          sc.start,\n\t\t\tEnd:            sc.end,\n\t\t})\n\t}\n\treturn out\n}",
      "contextualizedText": "// internal/chunk/code.go \u003e function lineChunks\n\n// lineChunks splits raw content by lines into budget-sized chunks, used as the\n// fallback when no grammar applies or parsing fails.\nfunc lineChunks(content []byte, prefix string, maxChunkSize int) []ChunkInfo {\n\ttext := string(content)\n\tif strings.TrimSpace(text) == \"\" {\n\t\treturn nil\n\t}\n\tvar out []ChunkInfo\n\tfor _, sc := range splitCodeByLines(text, Position{Line: 1, Col: 1}, maxChunkSize) {\n\t\tout = append(out, ChunkInfo{\n\t\t\tText:           sc.text,\n\t\t\tHeadingContext: prefix,\n\t\t\tStart:          sc.start,\n\t\t\tEnd:            sc.end,\n\t\t})\n\t}\n\treturn out\n}",
