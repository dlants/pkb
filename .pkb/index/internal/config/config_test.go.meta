    {
      "text": "func TestLoadMergesOverDefaults(t *testing.T) {\n\tdir := t.TempDir()\n\trequire.NoError(t, os.WriteFile(filepath.Join(dir, \"pkb.toml\"), []byte(`\n[embedding]\nprovider = \"voyage\"\nmodel = \"my-model\"\ndimensions = 512\n`), 0o644))\n\n\tcfg, err := Load(dir)\n\trequire.NoError(t, err)\n\trequire.Equal(t, \"my-model\", cfg.Embedding.Model)\n\trequire.Equal(t, 512, cfg.Embedding.Dimensions)\n}",
      "contextualizedText": "// internal/config/config_test.go \u003e function TestLoadMergesOverDefaults\n\nfunc TestLoadMergesOverDefaults(t *testing.T) {\n\tdir := t.TempDir()\n\trequire.NoError(t, os.WriteFile(filepath.Join(dir, \"pkb.toml\"), []byte(`\n[embedding]\nprovider = \"voyage\"\nmodel = \"my-model\"\ndimensions = 512\n`), 0o644))\n\n\tcfg, err := Load(dir)\n\trequire.NoError(t, err)\n\trequire.Equal(t, \"my-model\", cfg.Embedding.Model)\n\trequire.Equal(t, 512, cfg.Embedding.Dimensions)\n}",
      "headingContext": "internal/config/config_test.go \u003e function TestLoadMergesOverDefaults",
