      "text": "func TestMissingConfigReturnsDefaults(t *testing.T) {\n\tcfg, err := Load(t.TempDir())\n\trequire.NoError(t, err)\n\trequire.Equal(t, Default(), cfg)\n}",
      "contextualizedText": "// internal/config/config_test.go \u003e function TestMissingConfigReturnsDefaults\n\nfunc TestMissingConfigReturnsDefaults(t *testing.T) {\n\tcfg, err := Load(t.TempDir())\n\trequire.NoError(t, err)\n\trequire.Equal(t, Default(), cfg)\n}",
