    {
      "text": "func (r *recordingModel) EmbedChunks(chunks []string) ([]embed.Embedding, error) {\n\tr.mu.Lock()\n\tif r.failOnce {\n\t\tr.failOnce = false\n\t\tr.mu.Unlock()\n\t\treturn nil, fmt.Errorf(\"injected embed failure\")\n\t}\n\tr.embedded = append(r.embedded, chunks...)\n\tr.mu.Unlock()\n\treturn r.MockModel.EmbedChunks(chunks)\n}",
      "contextualizedText": "// internal/index/manager_test.go \u003e method EmbedChunks\n\nfunc (r *recordingModel) EmbedChunks(chunks []string) ([]embed.Embedding, error) {\n\tr.mu.Lock()\n\tif r.failOnce {\n\t\tr.failOnce = false\n\t\tr.mu.Unlock()\n\t\treturn nil, fmt.Errorf(\"injected embed failure\")\n\t}\n\tr.embedded = append(r.embedded, chunks...)\n\tr.mu.Unlock()\n\treturn r.MockModel.EmbedChunks(chunks)\n}",
      "headingContext": "internal/index/manager_test.go \u003e method EmbedChunks",
