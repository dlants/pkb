      "text": "// recordingModel wraps a mock embedding model and captures the exact chunk\n// strings passed to EmbedChunks so tests can assert what was embedded.\ntype recordingModel struct {\n\t*embed.MockModel\n\tmu       sync.Mutex\n\tembedded []string\n\tfailOnce bool\n}",
      "contextualizedText": "// internal/index/manager_test.go \u003e type recordingModel\n\n// recordingModel wraps a mock embedding model and captures the exact chunk\n// strings passed to EmbedChunks so tests can assert what was embedded.\ntype recordingModel struct {\n\t*embed.MockModel\n\tmu       sync.Mutex\n\tembedded []string\n\tfailOnce bool\n}",
      "headingContext": "internal/index/manager_test.go \u003e type recordingModel",
      "startLine": 255,
