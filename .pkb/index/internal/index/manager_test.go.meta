      "text": "func TestReusesUnchangedChunksCode(t *testing.T) {\n\th := newHarness(t)\n\th.write(\"p.go\", \"package p\\n\\nfunc Alpha() int {\\n\\treturn 1\\n}\\n\\nfunc Beta() int {\\n\\treturn 2\\n}\\n\\nfunc Gamma() int {\\n\\treturn 3\\n}\\n\")\n\th.commit(\"init\")\n\n\tmodel := embed.NewMockModel(\"mock\", 3)\n\to, st := h.opts(t, model)\n\tdefer st.Close()\n\n\t_, err := Reindex(o)\n\trequire.NoError(t, err)\n\ttotal := model.ChunkCount()\n\trequire.Greater(t, total, 1, \"fixture should produce multiple chunks\")\n\n\t// Change only the body of one function.\n\th.write(\"p.go\", \"package p\\n\\nfunc Alpha() int {\\n\\treturn 1\\n}\\n\\nfunc Beta() int {\\n\\treturn 22\\n}\\n\\nfunc Gamma() int {\\n\\treturn 3\\n}\\n\")\n\th.commit(\"edit beta\")\n\n\t_, err = Reindex(o)\n\trequire.NoError(t, err)\n\tdelta := model.ChunkCount() - total\n\trequire.Greater(t, delta, 0, \"changed function must re-embed\")\n\trequire.Less(t, delta, total, \"unchanged functions must be reused\")\n}",
      "contextualizedText": "// internal/index/manager_test.go \u003e function TestReusesUnchangedChunksCode\n\nfunc TestReusesUnchangedChunksCode(t *testing.T) {\n\th := newHarness(t)\n\th.write(\"p.go\", \"package p\\n\\nfunc Alpha() int {\\n\\treturn 1\\n}\\n\\nfunc Beta() int {\\n\\treturn 2\\n}\\n\\nfunc Gamma() int {\\n\\treturn 3\\n}\\n\")\n\th.commit(\"init\")\n\n\tmodel := embed.NewMockModel(\"mock\", 3)\n\to, st := h.opts(t, model)\n\tdefer st.Close()\n\n\t_, err := Reindex(o)\n\trequire.NoError(t, err)\n\ttotal := model.ChunkCount()\n\trequire.Greater(t, total, 1, \"fixture should produce multiple chunks\")\n\n\t// Change only the body of one function.\n\th.write(\"p.go\", \"package p\\n\\nfunc Alpha() int {\\n\\treturn 1\\n}\\n\\nfunc Beta() int {\\n\\treturn 22\\n}\\n\\nfunc Gamma() int {\\n\\treturn 3\\n}\\n\")\n\th.commit(\"edit beta\")\n\n\t_, err = Reindex(o)\n\trequire.NoError(t, err)\n\tdelta := model.ChunkCount() - total\n\trequire.Greater(t, delta, 0, \"changed function must re-embed\")\n\trequire.Less(t, delta, total, \"unchanged functions must be reused\")\n}",
      "headingContext": "internal/index/manager_test.go \u003e function TestReusesUnchangedChunksCode",
      "startLine": 319,
      "startCol": 1,
      "endLine": 342,
      "endCol": 2
    },
    {
      "text": "func bigClass(name string) string {\n\tvar b strings.Builder\n\tb.WriteString(\"class \" + name + \" {\\n\")\n\tfor i := 0; i \u003c 12; i++ {\n\t\tfmt.Fprintf(\u0026b, \"  method%c() {\\n\", 'a'+i)\n\t\tfor j := 0; j \u003c 6; j++ {\n\t\t\tb.WriteString(\"    const x = 'padding padding padding padding padding';\\n\")\n\t\t}\n\t\tb.WriteString(\"    return 1;\\n  }\\n\")\n\t}\n\tb.WriteString(\"}\\n\")\n\treturn b.String()\n}",
      "contextualizedText": "// internal/index/manager_test.go \u003e function bigClass\n\nfunc bigClass(name string) string {\n\tvar b strings.Builder\n\tb.WriteString(\"class \" + name + \" {\\n\")\n\tfor i := 0; i \u003c 12; i++ {\n\t\tfmt.Fprintf(\u0026b, \"  method%c() {\\n\", 'a'+i)\n\t\tfor j := 0; j \u003c 6; j++ {\n\t\t\tb.WriteString(\"    const x = 'padding padding padding padding padding';\\n\")\n\t\t}\n\t\tb.WriteString(\"    return 1;\\n  }\\n\")\n\t}\n\tb.WriteString(\"}\\n\")\n\treturn b.String()\n}",
      "headingContext": "internal/index/manager_test.go \u003e function bigClass",
      "startLine": 344,
      "startCol": 1,
      "endLine": 356,
      "endCol": 2
    },
    {
      "text": "func TestReindexOnParentClassRenameCode(t *testing.T) {\n\th := newHarness(t)\n\th.write(\"f.ts\", bigClass(\"Foo\"))\n\th.commit(\"init\")\n\n\tmodel := embed.NewMockModel(\"mock\", 3)\n\to, st := h.opts(t, model)\n\tdefer st.Close()\n\n\t_, err := Reindex(o)\n\trequire.NoError(t, err)\n\ttotal := model.ChunkCount()\n\trequire.Greater(t, total, 2, \"fixture should split into many method chunks\")\n\n\t// Rename the enclosing class. Method-body text is identical, but the class\n\t// is a parent breadcrumb of every method chunk, so all must re-embed.\n\th.write(\"f.ts\", bigClass(\"Bar\"))\n\th.commit(\"rename class\")\n\n\t_, err = Reindex(o)\n\trequire.NoError(t, err)\n\trequire.Equal(t, total*2, model.ChunkCount(), \"renaming parent class must re-embed all chunks\")\n}",
      "contextualizedText": "// internal/index/manager_test.go \u003e function TestReindexOnParentClassRenameCode\n\nfunc TestReindexOnParentClassRenameCode(t *testing.T) {\n\th := newHarness(t)\n\th.write(\"f.ts\", bigClass(\"Foo\"))\n\th.commit(\"init\")\n\n\tmodel := embed.NewMockModel(\"mock\", 3)\n\to, st := h.opts(t, model)\n\tdefer st.Close()\n\n\t_, err := Reindex(o)\n\trequire.NoError(t, err)\n\ttotal := model.ChunkCount()\n\trequire.Greater(t, total, 2, \"fixture should split into many method chunks\")\n\n\t// Rename the enclosing class. Method-body text is identical, but the class\n\t// is a parent breadcrumb of every method chunk, so all must re-embed.\n\th.write(\"f.ts\", bigClass(\"Bar\"))\n\th.commit(\"rename class\")\n\n\t_, err = Reindex(o)\n\trequire.NoError(t, err)\n\trequire.Equal(t, total*2, model.ChunkCount(), \"renaming parent class must re-embed all chunks\")\n}",
      "headingContext": "internal/index/manager_test.go \u003e function TestReindexOnParentClassRenameCode",
