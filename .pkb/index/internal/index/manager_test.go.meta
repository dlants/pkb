      "text": "func newHarness(t *testing.T) *harness {\n\tt.Helper()\n\troot := t.TempDir()\n\th := \u0026harness{t: t, root: root}\n\th.git(\"init\")\n\th.git(\"config\", \"user.email\", \"test@example.com\")\n\th.git(\"config\", \"user.name\", \"Test\")\n\th.git(\"config\", \"commit.gpgsign\", \"false\")\n\th.git(\"checkout\", \"-b\", \"master\")\n\treturn h\n}",
      "contextualizedText": "// internal/index/manager_test.go \u003e function newHarness\n\nfunc newHarness(t *testing.T) *harness {\n\tt.Helper()\n\troot := t.TempDir()\n\th := \u0026harness{t: t, root: root}\n\th.git(\"init\")\n\th.git(\"config\", \"user.email\", \"test@example.com\")\n\th.git(\"config\", \"user.name\", \"Test\")\n\th.git(\"config\", \"commit.gpgsign\", \"false\")\n\th.git(\"checkout\", \"-b\", \"master\")\n\treturn h\n}",
