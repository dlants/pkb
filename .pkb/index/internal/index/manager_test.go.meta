      "text": "func TestNoOpWhenNothingChanged(t *testing.T) {\n\th := newHarness(t)\n\th.write(\"a.md\", \"# A\\n\\nalpha\")\n\th.commit(\"init\")\n\n\tmodel := embed.NewMockModel(\"mock\", 3)\n\to, st := h.opts(t, model)\n\tdefer st.Close()\n\n\t_, err := Reindex(o)\n\trequire.NoError(t, err)\n\tcalls := model.DocumentCalls()\n\trequire.Greater(t, calls, 0)\n\n\t_, err = Reindex(o)\n\trequire.NoError(t, err)\n\trequire.Equal(t, calls, model.DocumentCalls(), \"second reindex should embed nothing\")\n}",
      "contextualizedText": "// internal/index/manager_test.go \u003e function TestNoOpWhenNothingChanged\n\nfunc TestNoOpWhenNothingChanged(t *testing.T) {\n\th := newHarness(t)\n\th.write(\"a.md\", \"# A\\n\\nalpha\")\n\th.commit(\"init\")\n\n\tmodel := embed.NewMockModel(\"mock\", 3)\n\to, st := h.opts(t, model)\n\tdefer st.Close()\n\n\t_, err := Reindex(o)\n\trequire.NoError(t, err)\n\tcalls := model.DocumentCalls()\n\trequire.Greater(t, calls, 0)\n\n\t_, err = Reindex(o)\n\trequire.NoError(t, err)\n\trequire.Equal(t, calls, model.DocumentCalls(), \"second reindex should embed nothing\")\n}",
