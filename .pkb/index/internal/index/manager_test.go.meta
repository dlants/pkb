      "text": "func TestTextFileUnchangedBlobReusesAll(t *testing.T) {\n\th := newHarness(t)\n\th.write(\"doc.md\", \"# Top\\n\\nintro paragraph\\n\\n## Sub\\n\\nnested paragraph\")\n\th.commit(\"init\")\n\n\tmodel := embed.NewMockModel(\"mock\", 3)\n\to, st := h.opts(t, model)\n\tdefer st.Close()\n\n\t_, err := Reindex(o)\n\trequire.NoError(t, err)\n\tcalls := model.DocumentCalls()\n\n\t// No change at all: the whole file is reused via blob_sha, nothing re-embeds.\n\th.commit(\"empty\")\n\t_, err = Reindex(o)\n\trequire.NoError(t, err)\n\trequire.Equal(t, calls, model.DocumentCalls(), \"unchanged text file should embed nothing\")\n}",
      "contextualizedText": "// internal/index/manager_test.go \u003e function TestTextFileUnchangedBlobReusesAll\n\nfunc TestTextFileUnchangedBlobReusesAll(t *testing.T) {\n\th := newHarness(t)\n\th.write(\"doc.md\", \"# Top\\n\\nintro paragraph\\n\\n## Sub\\n\\nnested paragraph\")\n\th.commit(\"init\")\n\n\tmodel := embed.NewMockModel(\"mock\", 3)\n\to, st := h.opts(t, model)\n\tdefer st.Close()\n\n\t_, err := Reindex(o)\n\trequire.NoError(t, err)\n\tcalls := model.DocumentCalls()\n\n\t// No change at all: the whole file is reused via blob_sha, nothing re-embeds.\n\th.commit(\"empty\")\n\t_, err = Reindex(o)\n\trequire.NoError(t, err)\n\trequire.Equal(t, calls, model.DocumentCalls(), \"unchanged text file should embed nothing\")\n}",
      "headingContext": "internal/index/manager_test.go \u003e function TestTextFileUnchangedBlobReusesAll",
      "startLine": 235,
      "startCol": 1,
      "endLine": 253,
      "endCol": 2
