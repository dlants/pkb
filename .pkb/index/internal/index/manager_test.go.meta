    {
      "text": "func issueStrings(rep HealthReport) []string {\n\tout := make([]string, len(rep.Issues))\n\tfor i, iss := range rep.Issues {\n\t\tif iss.Path == \"\" {\n\t\t\tout[i] = iss.Msg\n\t\t} else {\n\t\t\tout[i] = iss.Path + \": \" + iss.Msg\n\t\t}\n\t}\n\treturn out\n}",
      "contextualizedText": "// internal/index/manager_test.go \u003e function issueStrings\n\nfunc issueStrings(rep HealthReport) []string {\n\tout := make([]string, len(rep.Issues))\n\tfor i, iss := range rep.Issues {\n\t\tif iss.Path == \"\" {\n\t\t\tout[i] = iss.Msg\n\t\t} else {\n\t\t\tout[i] = iss.Path + \": \" + iss.Msg\n\t\t}\n\t}\n\treturn out\n}",
