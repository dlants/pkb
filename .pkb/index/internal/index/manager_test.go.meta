      "text": "func (r *recordingContextModel) EmbedDocument(document string) ([]embed.ContextualChunk, error) {\n\tr.mu.Lock()\n\tr.docs = append(r.docs, document)\n\tr.mu.Unlock()\n\treturn r.MockModel.EmbedDocument(document)\n}",
      "contextualizedText": "// internal/index/manager_test.go \u003e method EmbedDocument\n\nfunc (r *recordingContextModel) EmbedDocument(document string) ([]embed.ContextualChunk, error) {\n\tr.mu.Lock()\n\tr.docs = append(r.docs, document)\n\tr.mu.Unlock()\n\treturn r.MockModel.EmbedDocument(document)\n}",
