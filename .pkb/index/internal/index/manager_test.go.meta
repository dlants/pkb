      "text": "func (h *harness) write(rel, content string) {\n\th.t.Helper()\n\tfull := filepath.Join(h.root, rel)\n\trequire.NoError(h.t, os.MkdirAll(filepath.Dir(full), 0o755))\n\trequire.NoError(h.t, os.WriteFile(full, []byte(content), 0o644))\n}",
