      "startCol": 1,
      "endLine": 274,
      "endCol": 2
    },
    {
      "text": "func (r *recordingModel) inputs() []string {\n\tr.mu.Lock()\n\tdefer r.mu.Unlock()\n\treturn append([]string(nil), r.embedded...)\n}",
      "contextualizedText": "// internal/index/manager_test.go \u003e method inputs\n\nfunc (r *recordingModel) inputs() []string {\n\tr.mu.Lock()\n\tdefer r.mu.Unlock()\n\treturn append([]string(nil), r.embedded...)\n}",
