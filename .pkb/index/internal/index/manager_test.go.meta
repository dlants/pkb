      "text": "func (h *harness) git(args ...string) string {\n\th.t.Helper()\n\tcmd := exec.Command(\"git\", args...)\n\tcmd.Dir = h.root\n\tout, err := cmd.CombinedOutput()\n\trequire.NoErrorf(h.t, err, \"git %v: %s\", args, out)\n\treturn string(out)\n}",
