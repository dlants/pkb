      "text": "package index\n\nimport (\n\t\"strings\"\n\t\"testing\"\n\n\t\"github.com/dlants/pkb/internal/chunk\"\n\t\"github.com/dlants/pkb/internal/filetype\"\n\t\"github.com/dlants/pkb/internal/paths\"\n)",
      "contextualizedText": "// internal/index/reconstruct_test.go\n\npackage index\n\nimport (\n\t\"strings\"\n\t\"testing\"\n\n\t\"github.com/dlants/pkb/internal/chunk\"\n\t\"github.com/dlants/pkb/internal/filetype\"\n\t\"github.com/dlants/pkb/internal/paths\"\n)",
