    {
      "text": "// The mirror tree is now the up-to-date source of truth; refresh the derived\n\t// SQLite cache from it so stats/state counts and queries stay correct.\n\tif err := o.syncCache(models); err != nil {\n\t\treturn State{}, err\n\t}\n\n\tvar stats store.Stats\n\tfor _, m := range models {\n\t\ts, err := o.Store.Stats(m.ModelName())\n\t\tif err != nil {\n\t\t\treturn State{}, err\n\t\t}\n\t\tstats.Files += s.Files\n\t\tstats.Chunks += s.Chunks\n\t}\n\tst := State{\n\t\tCommit:     targetSha,\n\t\tFileCount:  stats.Files,\n\t\tChunkCount: stats.Chunks,\n\t}\n\tif err := writeState(repoRoot, st); err != nil {\n\t\treturn State{}, err\n\t}\n\tif err := o.Store.Vacuum(); err != nil {\n\t\treturn State{}, err\n\t}\n\treturn st, nil\n}",
      "contextualizedText": "// internal/index/manager.go \u003e function Reindex\n\n// The mirror tree is now the up-to-date source of truth; refresh the derived\n\t// SQLite cache from it so stats/state counts and queries stay correct.\n\tif err := o.syncCache(models); err != nil {\n\t\treturn State{}, err\n\t}\n\n\tvar stats store.Stats\n\tfor _, m := range models {\n\t\ts, err := o.Store.Stats(m.ModelName())\n\t\tif err != nil {\n\t\t\treturn State{}, err\n\t\t}\n\t\tstats.Files += s.Files\n\t\tstats.Chunks += s.Chunks\n\t}\n\tst := State{\n\t\tCommit:     targetSha,\n\t\tFileCount:  stats.Files,\n\t\tChunkCount: stats.Chunks,\n\t}\n\tif err := writeState(repoRoot, st); err != nil {\n\t\treturn State{}, err\n\t}\n\tif err := o.Store.Vacuum(); err != nil {\n\t\treturn State{}, err\n\t}\n\treturn st, nil\n}",
      "headingContext": "internal/index/manager.go \u003e function Reindex",
