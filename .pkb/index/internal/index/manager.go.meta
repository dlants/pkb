      "endLine": 138,
      "endCol": 2
    },
    {
      "text": "// candidate reports whether a path should be indexed: a recognized code file,\n// or an allowlisted text file; never the .pkb state dir; not ignored.\nfunc (o *Options) candidate(path paths.GitRootRelativePath) bool {\n\tif strings.HasPrefix(string(path), \".pkb/\") {\n\t\treturn false\n\t}\n\tif string(path) == statePath {\n\t\treturn false\n\t}\n\tif o.Ignore != nil \u0026\u0026 o.Ignore.Match(path) {\n\t\treturn false\n\t}\n\tif o.route(path) == filetype.Code {\n\t\treturn true\n\t}\n\t_, ok := textExts[strings.ToLower(filepath.Ext(string(path)))]\n\treturn ok\n}",
      "contextualizedText": "// internal/index/manager.go \u003e method candidate\n\n// candidate reports whether a path should be indexed: a recognized code file,\n// or an allowlisted text file; never the .pkb state dir; not ignored.\nfunc (o *Options) candidate(path paths.GitRootRelativePath) bool {\n\tif strings.HasPrefix(string(path), \".pkb/\") {\n\t\treturn false\n\t}\n\tif string(path) == statePath {\n\t\treturn false\n\t}\n\tif o.Ignore != nil \u0026\u0026 o.Ignore.Match(path) {\n\t\treturn false\n\t}\n\tif o.route(path) == filetype.Code {\n\t\treturn true\n\t}\n\t_, ok := textExts[strings.ToLower(filepath.Ext(string(path)))]\n\treturn ok\n}",
      "headingContext": "internal/index/manager.go \u003e method candidate",
      "startLine": 140,
      "startCol": 1,
      "endLine": 157,
      "endCol": 2
    },
    {
      "text": "func readState(repoRoot string) (*State, error) {\n\tdata, err := os.ReadFile(filepath.Join(repoRoot, statePath))\n\tif err != nil {\n\t\tif os.IsNotExist(err) {\n\t\t\treturn nil, nil\n\t\t}\n\t\treturn nil, err\n\t}\n\tvar s State\n\tif err := toml.Unmarshal(data, \u0026s); err != nil {\n\t\treturn nil, err\n\t}\n\treturn \u0026s, nil\n}",
      "contextualizedText": "// internal/index/manager.go \u003e function readState\n\nfunc readState(repoRoot string) (*State, error) {\n\tdata, err := os.ReadFile(filepath.Join(repoRoot, statePath))\n\tif err != nil {\n\t\tif os.IsNotExist(err) {\n\t\t\treturn nil, nil\n\t\t}\n\t\treturn nil, err\n\t}\n\tvar s State\n\tif err := toml.Unmarshal(data, \u0026s); err != nil {\n\t\treturn nil, err\n\t}\n\treturn \u0026s, nil\n}",
      "headingContext": "internal/index/manager.go \u003e function readState",
      "startLine": 159,
      "startCol": 1,
      "endLine": 172,
      "endCol": 2
    },
    {
      "text": "func writeState(repoRoot string, s State) error {\n\tvar buf bytes.Buffer\n\tif err := toml.NewEncoder(\u0026buf).Encode(s); err != nil {\n\t\treturn err\n\t}\n\treturn os.WriteFile(filepath.Join(repoRoot, statePath), buf.Bytes(), 0o644)\n}",
      "contextualizedText": "// internal/index/manager.go \u003e function writeState\n\nfunc writeState(repoRoot string, s State) error {\n\tvar buf bytes.Buffer\n\tif err := toml.NewEncoder(\u0026buf).Encode(s); err != nil {\n\t\treturn err\n\t}\n\treturn os.WriteFile(filepath.Join(repoRoot, statePath), buf.Bytes(), 0o644)\n}",
      "headingContext": "internal/index/manager.go \u003e function writeState",
      "startLine": 174,
