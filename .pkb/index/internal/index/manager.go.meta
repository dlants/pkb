      "endCol": 2
    },
    {
      "text": "// route returns the file type for a path, applying any extension overrides.\nfunc (o *Options) route(path paths.GitRootRelativePath) filetype.FileType {\n\text := strings.ToLower(filepath.Ext(string(path)))\n\tif o.ExtOverrides != nil {\n\t\tif t, ok := o.ExtOverrides[ext]; ok {\n\t\t\tif t == \"code\" {\n\t\t\t\treturn filetype.Code\n\t\t\t}\n\t\t\treturn filetype.Text\n\t\t}\n\t}\n\treturn filetype.RoutePath(string(path)).Type\n}",
      "contextualizedText": "// internal/index/manager.go \u003e method route\n\n// route returns the file type for a path, applying any extension overrides.\nfunc (o *Options) route(path paths.GitRootRelativePath) filetype.FileType {\n\text := strings.ToLower(filepath.Ext(string(path)))\n\tif o.ExtOverrides != nil {\n\t\tif t, ok := o.ExtOverrides[ext]; ok {\n\t\t\tif t == \"code\" {\n\t\t\t\treturn filetype.Code\n\t\t\t}\n\t\t\treturn filetype.Text\n\t\t}\n\t}\n\treturn filetype.RoutePath(string(path)).Type\n}",
      "headingContext": "internal/index/manager.go \u003e method route",
      "startLine": 105,
      "startCol": 1,
      "endLine": 117,
      "endCol": 2
    },
    {
      "text": "// textExts is the allowlist of indexable text extensions.\nvar textExts = map[string]struct{}{\n\t\".md\":       {},\n\t\".markdown\": {},\n\t\".txt\":      {},\n}",
      "contextualizedText": "// internal/index/manager.go\n\n// textExts is the allowlist of indexable text extensions.\nvar textExts = map[string]struct{}{\n\t\".md\":       {},\n\t\".markdown\": {},\n\t\".txt\":      {},\n}",
      "headingContext": "internal/index/manager.go",
