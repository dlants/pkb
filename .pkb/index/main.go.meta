    {
      "text": "func readState(repoRoot string) (*state, error) {\n\tdata, err := os.ReadFile(filepath.Join(repoRoot, \"pkb-state.toml\"))\n\tif err != nil {\n\t\tif os.IsNotExist(err) {\n\t\t\treturn nil, nil\n\t\t}\n\t\treturn nil, err\n\t}\n\tvar s state\n\tif err := toml.Unmarshal(data, \u0026s); err != nil {\n\t\treturn nil, err\n\t}\n\treturn \u0026s, nil\n}",
      "contextualizedText": "// main.go \u003e function readState\n\nfunc readState(repoRoot string) (*state, error) {\n\tdata, err := os.ReadFile(filepath.Join(repoRoot, \"pkb-state.toml\"))\n\tif err != nil {\n\t\tif os.IsNotExist(err) {\n\t\t\treturn nil, nil\n\t\t}\n\t\treturn nil, err\n\t}\n\tvar s state\n\tif err := toml.Unmarshal(data, \u0026s); err != nil {\n\t\treturn nil, err\n\t}\n\treturn \u0026s, nil\n}",
